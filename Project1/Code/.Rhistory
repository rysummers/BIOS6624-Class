miss_summary <- ana2 %>%
summarise(
# viral load
vl_miss0_have2 = sum(is.na(log_vload0) & !is.na(log_vload2)),
vl_have0_miss2 = sum(!is.na(log_vload0) & is.na(log_vload2)),
vl_both        = sum(!is.na(log_vload0) & !is.na(log_vload2)),
vl_none        = sum(is.na(log_vload0) & is.na(log_vload2)),
# CD4
cd4_miss0_have2 = sum(is.na(cd40) & !is.na(cd42)),
cd4_have0_miss2 = sum(!is.na(cd40) & is.na(cd42)),
cd4_both        = sum(!is.na(cd40) & !is.na(cd42)),
cd4_none        = sum(is.na(cd40) & is.na(cd42)),
# physical QOL
phys_miss0_have2 = sum(is.na(physical0) & !is.na(physical2)),
phys_have0_miss2 = sum(!is.na(physical0) & is.na(physical2)),
phys_both        = sum(!is.na(physical0) & !is.na(physical2)),
phys_none        = sum(is.na(physical0) & is.na(physical2)),
# mental QOL
ment_miss0_have2 = sum(is.na(mental0) & !is.na(mental2)),
ment_have0_miss2 = sum(!is.na(mental0) & is.na(mental2)),
ment_both        = sum(!is.na(mental0) & !is.na(mental2)),
ment_none        = sum(is.na(mental0) & is.na(mental2))
)
View(miss_summary)
pairs <- tribble(
~outcome, ~base, ~yr2,
"viral load", "log_vload0", "log_vload2",
"CD4", "cd40", "cd42",
"physical QOL", "physical0", "physical2",
"mental QOL", "mental0", "mental2"
)
miss_tbl <- pairs %>%
rowwise() %>%
mutate(
miss0_have2 = sum(is.na(ana2[[base]]) & !is.na(ana2[[yr2]])),
have0_miss2 = sum(!is.na(ana2[[base]]) & is.na(ana2[[yr2]])),
both        = sum(!is.na(ana2[[base]]) & !is.na(ana2[[yr2]])),
none        = sum(is.na(ana2[[base]]) & is.na(ana2[[yr2]]))
) %>%
ungroup()
View(miss_tbl)
