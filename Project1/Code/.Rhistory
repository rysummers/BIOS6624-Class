fit_models <- function(outcome, baseline, data) {
# model form - consisitent across all models
formula <- as.formula(
paste(outcome, "~ hard0 +", baseline,
"+ age0 + bmi0 + smoke0 + educ0 + race0"))
# Frequentist model
lm_fit <- lm(formula, data = data)
# Bayes model
brm_fit <- brm(
formula,
data = data,
family = gaussian(),
prior = c(
# ***the priors need to be more uniform or more robust to different models**
prior(normal(0, 1), class = "b"),
prior(normal(0, 1000), class = "Intercept"), # less interpretable so make var wider
prior(student_t(3, 0, 500), class = "sigma")), # half-t - standard
chains = 4, cores = 6, iter = 2000,
refresh = 0)
# export model results into a list
list(lm = lm_fit, brm = brm_fit)
}
t0 <- Sys.time()
options(warn = -1) # GenomicAlignments/SummarizedExperiment warnings
model.fits <- imap(outcomes, ~ fit_models(.x$y, .x$baseline, ana2_cc))
options(warn = 0)
t1 <- Sys.time()
message("Runtime: ",
round(as.numeric(difftime(t1, t0, units = "mins")), 2),
" minutes")
