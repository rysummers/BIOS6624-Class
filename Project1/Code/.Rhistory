make_dropout_tbl <- function(data, base, yr2, status_name){
data %>%
mutate(
status = case_when(
!is.na(.data[[base]]) & !is.na(.data[[yr2]]) ~ "Complete",
!is.na(.data[[base]]) &  is.na(.data[[yr2]]) ~ "Year 2 missing",
TRUE ~ NA_character_
)
) %>%
filter(!is.na(status)) %>%
tbl_summary(
by = status,
include = c(
hard0, age0, bmi0, smoke0, educ0, race0,
log_vload0, cd40, physical0, mental0, cesd0
)
) %>%
add_p()
}
tbl_vl   <- make_dropout_tbl(ana2, "log_vload0", "log_vload2")
tbl_cd4  <- make_dropout_tbl(ana2, "cd40", "cd42")
tbl_phys <- make_dropout_tbl(ana2, "physical0", "physical2")
tbl_ment <- make_dropout_tbl(ana2, "mental0", "mental2")
tbl_vl;tbl_cd4;tbl_phys;tbl_ment
