statistic = round(statistic, 3),
p.value = round(p.value, 3),
conf.low = round(conf.low, 3),
conf.high = round(conf.high, 3),
vload_copies_ml = round(10^estimate, 3),
vload_ml_LL = round(10^conf.low, 3),
vload_ml_UL = round(10^conf.high, 3))
summary(model.fits$vload$lm)
summary(model.fits$vload$brm)
extract_effects <- function(lm_fit, brm_fit, outcome_name) {
# Frequentist
freq <- broom::tidy(lm_fit, conf.int = TRUE) %>%
filter(term == "hard0Yes") %>%
transmute(
outcome = outcome_name,
freq_est = estimate,
freq_lo = conf.low,
freq_hi = conf.high,
freq_p = p.value)
# Bayesian
draws <- posterior::as_draws_df(brm_fit)
beta <- draws$b_hard0Yes
bay <- tibble(
outcome = outcome_name,
bay_est = mean(beta),
bay_lo = quantile(beta, 0.025),
bay_hi = quantile(beta, 0.975),
bay_pr = mean(beta > 0))
# combine tables created above
left_join(freq, bay, by = "outcome")
}
results <- imap_dfr(model.fits, ~ extract_effects(.x$lm, .x$brm, .y))
results
extract_effects <- function(lm_fit, brm_fit, outcome_name) {
# Frequentist
freq <- broom::tidy(lm_fit, conf.int = TRUE) %>%
filter(term == "hard0Yes") %>%
transmute(
outcome = outcome_name,
freq_est = estimate,
freq_lo = conf.low,
freq_hi = conf.high,
freq_p = p.value)
# Bayesian
draws <- posterior::as_draws_df(brm_fit)
beta <- draws$b_hard0Yes
bay <- tibble(
outcome = outcome_name,
bay_est = mean(beta),
bay_lo = quantile(beta, 0.025),
bay_hi = quantile(beta, 0.975))
# combine tables created above
left_join(freq, bay, by = "outcome")
}
results <- imap_dfr(model.fits, ~ extract_effects(.x$lm, .x$brm, .y))
results
cd4.brm <- brm(
cd42 ~ hard0 + log_vload0 + age0 + bmi0 + smoke0 + educ0 + race0,
data = ana2_cc,
family = gaussian(),
prior = c(
# slope of 1 on log10 is 10-fold difference in viral load (weakly informative)
prior(normal(0, 1), class = "b"),
prior(normal(0, 5), class = "Intercept"),  # less interpretable so make var wider
prior(student_t(3, 0, 2.5), class = "sigma")), # residual SD (half-t)
chains = 4, cores = 6, iter = 4000)
summary(cd4.brm)
